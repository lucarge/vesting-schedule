{
  "name": "vestwise",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:app": "bun run --filter @vestwise/app dev",
    "dev:landing": "bun run --filter @vestwise/landing dev",
    "build": "bun run --filter '*' build",
    "build:app": "bun run --filter @vestwise/app build",
    "build:landing": "bun run --filter @vestwise/landing build",
    "lint": "eslint packages/",
    "format": "prettier --write \"packages/**/*.{ts,tsx}\"",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.57.1"
  }
}
